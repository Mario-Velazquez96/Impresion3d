# Tower Layers — environment variables.
# Copy to .env.local (gitignored) and fill in real values from the
# DEV/STAGING Supabase project. NEVER commit real secrets. NEVER target
# production. Only NEXT_PUBLIC_* values are browser-safe.

# Prisma — pooled connection (pgBouncer, port 6543). Used at app runtime.
# Server-only secret. Do NOT prefix with NEXT_PUBLIC_.
DATABASE_URL=

# Prisma — direct connection (port 5432). Used by `prisma migrate`.
# Server-only secret. Do NOT prefix with NEXT_PUBLIC_.
DIRECT_URL=

# Supabase project URL. Browser-safe.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable key (sb_publishable_…). Browser-safe.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase secret key (sb_secret_…). Server-only, bypasses RLS.
# Do NOT prefix with NEXT_PUBLIC_. Used by services/users.ts inviteUser to call
# the Supabase Admin API (createUser). Never expose to the client.
SUPABASE_SECRET_KEY=

# --- E2E / RLS test accounts (optional; for Playwright only) -----------------
# Test-only credentials for the auth + RLS E2E specs (e2e/auth.spec.ts,
# e2e/rls.spec.ts). The specs SKIP when these are unset. Never commit real
# values. These reference accounts that must already exist in the dev/staging
# Supabase project with the matching app role.
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
E2E_EMPLOYEE_EMAIL=
E2E_EMPLOYEE_PASSWORD=
